<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Carpinteria Artesanal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="~/font-awesome/css/all.min.css" rel="stylesheet" />
    <link href="~/font-awesome/css/all.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/CarpinteriaArtesanal.styles.css" asp-append-version="true" />

    
    <link href="~/scss/site.css" rel="stylesheet" />
    <link href="~/font-awesome/css/all.min.css" rel="stylesheet" />
    <link href="~/font-awesome/css/all.css" rel="stylesheet" />
</head>
<body>
    <!--hola-->
   <header>
    <nav class="navbar navbar-expand-lg bg-light text-dark">
        <div class="container-fluid">
                <div class="icono p-5">
                </div>
                <button class="navbar-toggler " type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation"  >
                    <span class="navbar-toggler-icon "></span>
                </button>
                <div class="navbar-collapse collapse justify-content-between">
                    
                    <ul class="navbar-nav d-flex align-items-center justify-content-center">
                        <li class="nav-item">
                            <a href="#" class="nav-link ">
                                <i class="fa-solid fa-hammer me-2"></i>
                                Nuestros Trabajos
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="#" class="nav-link">
                                Productos
                                <i class="fa-solid fa-chevron-down"></i>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="#" class="nav-link">
                                <i class="fa-solid fa-warehouse me-2"></i>
                                Sobre Nosotros
                            </a>
                        </li>
                     
                        <li class="nav-item">
                            <a href="#" class="nav-link">
                                <i class="fa-solid fa-user-group"></i>
                                Conocenos
                            </a>
                        </li>

                    </ul>
                 
                    <button class="boton btn btn-primary">
                        <i class="fa-regular fa-user"></i> Contacto
                    </button>
                </div>
        </div>
      
    </nav>
   </header>
   <hr />

   <section class="portada">
       <div class="title-container">
           <h1>Bienvenidos a esta poronga</h1>
       </div>

       <div class="botones-container">
           <a class="button1">Click aca</a>
            <a class="button2">Prueba gratis</a>
       </div>
       
       
   </section>
    
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
